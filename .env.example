# ---------------------------------------------------------------------------
# deploy-templates — environment template
# ---------------------------------------------------------------------------
# Copy this file to .env and replace the dev defaults with real secrets before
# using anywhere other than your laptop. .env is gitignored.
#
#   cp .env.example .env
#
# Every value here has a safe local default baked into docker-compose.yml, so
# the stack also boots with no .env at all (dev-only).
# ---------------------------------------------------------------------------

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=workspace
POSTGRES_PORT=5432

# Least-privilege application role created by the initdb scripts. Your app
# connects as this role so Row Level Security policies apply.
APP_DB_USER=app
APP_DB_PASSWORD=change-me-app

# --- Redis ----------------------------------------------------------------
REDIS_PORT=6379

# --- MinIO / S3-compatible storage ---------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=workspace-documents

# --- API placeholder ------------------------------------------------------
API_PORT=8000
